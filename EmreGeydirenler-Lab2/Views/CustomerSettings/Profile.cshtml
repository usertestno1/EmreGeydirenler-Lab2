@model EmreGeydirenler_Lab2.Models.Customer
@{
    ViewData["Title"] = "Edit Company Profile";
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold">@ViewData["Title"]</h2>
    <p class="text-muted">Update your business information for QuTech billing.</p>
    @if (TempData["ProfileMessage"] is string profileMessage)
    {
        <div class="alert alert-success">@profileMessage</div>
    }
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <form asp-action="Profile" method="post">
                        <input asp-for="Id" type="hidden" />
                        <div class="mb-3">
                            <label asp-for="CompanyName" class="form-label fw-bold"></label>
                            <input asp-for="CompanyName" class="form-control form-control-lg" />
                            <span asp-validation-for="CompanyName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="TaxNumber" class="form-label fw-bold"></label>
                            <input asp-for="TaxNumber" class="form-control form-control-lg" />
                            <span asp-validation-for="TaxNumber" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold"></label>
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm mt-3">
                            Update Profile Information
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6 d-none d-md-block text-center mt-5">
            <div class="p-5 border rounded-circle d-inline-block bg-white shadow-sm">
                <i class="display-1 text-primary">🏢</i>
            </div>
            <p class="mt-3 text-muted">Your business identity is secure with us.</p>
        </div>
    </div>
</div>