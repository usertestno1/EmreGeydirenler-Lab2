@model EmreGeydirenler_Lab2.Models.AccountSetting
@{
    ViewData["Title"] = "Account Security Settings";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Security & Notifications</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">Manage your account security preferences and automated email alerts below.</p>
                    @if (TempData["SecurityMessage"] is string securityMessage)
                    {
                        <div class="alert alert-success">@securityMessage</div>
                    }

                    <form asp-action="Security" method="post">
                        <input asp-for="CustomerId" type="hidden" />
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                            <div>
                                <h6 class="fw-bold mb-0">Two-Factor Authentication (2FA)</h6>
                                <small class="text-muted">Adds an extra layer of security to your login process.</small>
                            </div>
                            <div class="form-check form-switch">
                                <input asp-for="TwoFactorEnabled" class="form-check-input" type="checkbox" role="switch" id="2faToggle">
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                            <div>
                                <h6 class="fw-bold mb-0">Email Notifications</h6>
                                <small class="text-muted">Receive alerts about system updates, billing, and failed logins.</small>
                            </div>
                            <div class="form-check form-switch">
                                <input asp-for="ReceiveEmailAlerts" class="form-check-input" type="checkbox" role="switch" id="emailToggle">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="newPassword" class="form-label fw-bold">New Password (optional)</label>
                            <input type="password" id="newPassword" name="newPassword" class="form-control" />
                            <small class="text-muted">Leave blank to keep your current password unchanged.</small>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                Save Security Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>