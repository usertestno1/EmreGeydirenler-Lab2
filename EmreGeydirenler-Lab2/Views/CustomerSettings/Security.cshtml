@{
    ViewData["Title"] = "Account Security Settings";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Security & Notifications</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">Manage your account security preferences and automated email alerts below.</p>

                    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                        <div>
                            <h6 class="fw-bold mb-0">Two-Factor Authentication (2FA)</h6>
                            <small class="text-muted">Adds an extra layer of security to your login process.</small>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="2faToggle" checked="@ViewBag.Is2FAEnabled">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                        <div>
                            <h6 class="fw-bold mb-0">Email Notifications</h6>
                            <small class="text-muted">Receive alerts about system updates, billing, and failed logins.</small>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="emailToggle" checked="@ViewBag.ReceiveAlerts">
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="button" class="btn btn-primary px-4 shadow-sm" onclick="alert('Security settings have been updated! (Simulated)');">
                            Save Security Changes
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>