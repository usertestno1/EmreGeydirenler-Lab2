@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 shadow-sm p-5 bg-white border rounded">
            <h1 class="mb-4 text-center">@ViewData["Title"]</h1>
            <p class="text-muted text-center mb-5">Last updated: March 26, 2026</p>

            <section class="mb-5">
                <h4 class="text-primary fw-bold">1. Information We Collect</h4>
                <p>QuTech SAAS collects information that you provide directly to us when you create an account, subscribe to a plan, or contact our support team. This includes company name, tax identification numbers, and contact details.</p>
            </section>

            <section class="mb-5">
                <h4 class="text-primary fw-bold">2. Use of Information</h4>
                <p>We use the information we collect to:</p>
                <ul>
                    <li>Provide, maintain, and improve our SAAS platform services.</li>
                    <li>Process billing, invoices, and payment transactions.</li>
                    <li>Generate audit trails and logs for your security and accountability.</li>
                    <li>Communicate with you about platform updates and security alerts.</li>
                </ul>
            </section>

            <section class="mb-5">
                <h4 class="text-primary fw-bold">3. Data Retention and Security</h4>
                <p>We implement industry-standard security measures to protect your data. Audit logs are stored for a minimum of 12 months to ensure compliance with our transparency standards. Your data is encrypted at rest and in transit.</p>
            </section>

            <div class="alert alert-info text-center mt-5">
                Questions about our policy? Contact our Data Protection Officer at <strong>security@qutech.com</strong>
            </div>
        </div>
    </div>
</div>