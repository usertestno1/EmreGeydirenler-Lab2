@{
    ViewData["Title"] = "My Subscription";
}

<div class="container mt-4">
    <h2 class="mb-4">Subscription Overview</h2>

    @if (TempData["UpgradeMessage"] is string upgradeMessage)
    {
        <div class="alert alert-success">@upgradeMessage</div>
    }
    
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="text-primary mb-0">Active Plan: <strong>@ViewBag.CurrentPlan</strong></h4>
                        <p class="text-muted mb-1">Current billing period ends in @ViewBag.DaysRemaining days.</p>
                        <p class="text-muted">Next billing date: <strong>@ViewBag.NextBillingDate</strong></p>
                    </div>
                    <a asp-action="Plans" class="btn btn-outline-primary btn-sm">Upgrade Plan</a>
                </div>
                
                <hr />

                <div class="mt-3">
                    <div class="d-flex justify-content-between">
                        <label class="fw-bold">Cloud Storage Usage</label>
                        <span class="text-muted">@ViewBag.StorageUsed</span>
                    </div>
                    <div class="progress mt-2" style="height: 15px;">
                        <div class="progress-bar bg-success shadow-sm" style="width: @ViewBag.StoragePercent%"></div>
                    </div>
                    <small class="text-muted">You have used @ViewBag.StoragePercent% of your storage limit.</small>
                </div>

                <div class="mt-4">
                    <div class="d-flex justify-content-between">
                        <label class="fw-bold">API Requests (Monthly)</label>
                        <span class="text-muted">@ViewBag.ApiUsed / @ViewBag.ApiLimit</span>
                    </div>
                    <div class="progress mt-2" style="height: 15px;">
                        <div class="progress-bar bg-info shadow-sm" style="width: @ViewBag.ApiPercent%"></div>
                    </div>
                    <small class="text-muted">@ViewBag.ApiPercent% of your monthly request quota.</small>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card bg-light border-0 p-3 shadow-sm">
                <h5 class="fw-bold">Need more space?</h5>
                <p class="small text-muted">Enterprise plans offer up to 500 GB storage and unlimited API requests for growing teams.</p>
                <a asp-action="Plans" class="btn btn-dark btn-sm w-100">View Enterprise</a>
            </div>

            <div class="card border-0 p-3 shadow-sm mt-3">
                <h5 class="fw-bold">Thinking about upgrading?</h5>
                <p class="small text-muted">Review better plans and compare your current monthly cost with higher tiers.</p>
                <a asp-action="Plans" class="btn btn-primary btn-sm w-100">Review Better Plans</a>
            </div>
        </div>
    </div>
</div>