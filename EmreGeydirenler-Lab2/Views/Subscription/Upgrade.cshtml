@{
    ViewData["Title"] = "Confirm Your Plan Upgrade";
    decimal currentPrice = ViewBag.CurrentPlanPrice ?? 0m;
    string currentPlanName = ViewBag.CurrentPlanName ?? "Current";
    string newPlanName = ViewBag.NewPlanName ?? "Selected";
    decimal newPlanPrice = ViewBag.NewPlanPrice ?? 0m;
    decimal difference = ViewBag.PriceDifference ?? (newPlanPrice - currentPrice);
    int selectedPlanId = ViewBag.SelectedPlanId ?? 0;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 text-center">Confirm Your Plan Selection</h4>
                </div>
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <p class="lead">You are switching from <strong>@currentPlanName Plan</strong> to <strong>@newPlanName Plan</strong>.</p>
                    </div>

                    <table class="table table-bordered mb-4">
                        <thead class="bg-light">
                            <tr>
                                <th>Item Description</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Current Plan Monthly Rate (@currentPlanName)</td>
                                <td class="text-end">AUD @currentPrice.ToString("F2")</td>
                            </tr>
                            <tr>
                                <td>New Plan Monthly Rate (@newPlanName)</td>
                                <td class="text-end">AUD @newPlanPrice.ToString("F2")</td>
                            </tr>
                            <tr>
                                <td>Monthly Price Difference</td>
                                <td class="text-end">AUD @difference.ToString("F2")</td>
                            </tr>
                            <tr class="fw-bold">
                                <td>Due Today</td>
                                <td class="text-end text-success">
                                    @(difference > 0 ? $"AUD {difference.ToString("F2")}" : "AUD 0.00")
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="alert @(difference <= 0 ? "alert-info" : "alert-warning") shadow-sm" role="alert">
                        <h5 class="alert-heading fw-bold">Important Note:</h5>
                        @if (difference <= 0)
                        {
                            <p class="mb-1">No extra payment is required today for this change.</p>
                            <p class="mb-0">From your next monthly billing cycle, the new plan price of <strong>AUD @newPlanPrice.ToString("F2")</strong> will apply.</p>
                        }
                        else
                        {
                            <p class="mb-1">You will pay <strong>AUD @difference.ToString("F2")</strong> now for the current billing period.</p>
                            <p class="mb-0">From your next monthly billing cycle, the new plan price of <strong>AUD @newPlanPrice.ToString("F2")</strong> will apply.</p>
                        }
                    </div>

                    <form asp-action="ConfirmUpgrade" method="post" class="mt-5 d-flex justify-content-center gap-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="planId" value="@selectedPlanId" />
                        <button type="submit" class="btn btn-success btn-lg px-5 shadow">Confirm Upgrade</button>
                        <a asp-action="Plans" class="btn btn-outline-secondary btn-lg px-5">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>