@{
    ViewData["Title"] = "Confirm Your Plan Upgrade";
    decimal currentPrice = ViewBag.CurrentPlanPrice ?? 0m;
    string currentPlanName = ViewBag.CurrentPlanName ?? "Current";
    string newPlanName = ViewBag.NewPlanName ?? "Selected";
    decimal newPlanPrice = ViewBag.NewPlanPrice ?? 0m;
    decimal difference = newPlanPrice - currentPrice;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 text-center">Confirm Your Plan Selection</h4>
                </div>
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <p class="lead">You are switching from <strong>@currentPlanName Plan</strong> to <strong>@newPlanName Plan</strong>.</p>
                    </div>

                    <table class="table table-bordered mb-4">
                        <thead class="bg-light">
                            <tr>
                                <th>Item Description</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>New Plan Monthly Rate (@newPlanName)</td>
                                <td class="text-end">$@newPlanPrice.ToString("F2")</td>
                            </tr>
                            <tr class="fw-bold">
                                <td>Due Today</td>
                                <td class="text-end text-success">
                                    @(difference > 0 ? $"${difference.ToString("F2")}" : "$0.00")
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="alert @(difference <= 0 ? "alert-info" : "alert-warning") shadow-sm" role="alert">
                        <h5 class="alert-heading fw-bold">Important Note:</h5>
                        @if (difference <= 0)
                        {
                            <p class="mb-0">No extra payment is required today. The new pricing will apply from your next billing cycle.</p>
                        }
                        else
                        {
                            <p class="mb-0">An extra payment of <strong>$@difference.ToString("F2")</strong> is required today to cover this billing period. Future renewals will use the new monthly rate.</p>
                        }
                    </div>

                    <div class="mt-5 d-flex justify-content-center gap-3">
                        <button type="button" class="btn btn-success btn-lg px-5 shadow"
                                onclick="alert('Transaction Completed! Your @newPlanName subscription is now processing.'); window.location.href='/Subscription/MySubscription?role=customer';">
                            Confirm & Pay
                        </button>
                        <a asp-action="Plans" asp-route-role="customer" class="btn btn-outline-secondary btn-lg px-5">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>