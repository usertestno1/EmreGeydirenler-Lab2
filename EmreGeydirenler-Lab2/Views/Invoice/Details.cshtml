@model EmreGeydirenler_Lab2.Models.Invoice
@{
    ViewData["Title"] = "Invoice Details";
}

<div class="container mt-5">
    <div class="card shadow w-75 mx-auto">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Invoice #@Model.Id</h4>
            <span class="badge @(Model.IsPaid ? "bg-success" : "bg-danger")">@(Model.IsPaid ? "Paid" : "Pending")</span>
        </div>
        <div class="card-body">
            <h5 class="card-title">Billed To: @Model.Customer.CompanyName</h5>
            <p class="card-text text-muted">Thank you for your business with QuTech SAAS.</p>
            <p class="card-text text-muted mb-1">Invoice Date: @Model.IssueDate.ToShortDateString()</p>
            <p class="card-text text-muted">Plan: @ViewBag.SubscriptionPlanName</p>
            <hr />
            <div class="d-flex justify-content-between align-items-center mt-4">
                <span class="fw-bold fs-5">Total Amount Due:</span>
                <span class="fs-3 text-success fw-bold">AUD @Model.TotalAmount.ToString("0.00")</span>
            </div>
            <div class="mt-5 text-end">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to Invoices</a>
                <button type="button" class="btn btn-primary ms-2" onclick="window.print()">Print Invoice</button>
            </div>
        </div>
    </div>
</div>