@model IEnumerable<EmreGeydirenler_Lab2.Models.AuditTrail>
@{
    ViewData["Title"] = "System Audit Logs";
}

<div class="d-flex justify-content-between align-items-center">
    <h2 class="text-danger">Security & Audit Logs</h2>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
</div>

<table class="table table-bordered table-hover mt-4 shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Time</th>
            <th>Action Description</th>
            <th>User ID</th>
            <th>User Role</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@log.ActionDescription</td>
                <td><code>@log.UserId</code></td>
                <td>@(log.User is EmreGeydirenler_Lab2.Models.Admin ? "Admin" : "Customer")</td>
            </tr>
        }
    </tbody>
</table>