@model IEnumerable<EmreGeydirenler_Lab2.Models.AdminCustomerListItemViewModel>

@{
    ViewData["Title"] = "Manage Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Manage Customers</h2>
        <p class="text-muted mb-0">View customer accounts, plans, and invoice status.</p>
    </div>
    <a asp-action="CreateCustomer" class="btn btn-success">Create Customer</a>
</div>

@if (TempData["CustomerMessage"] is string customerMessage)
{
    <div class="alert alert-success">@customerMessage</div>
}

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Customer ID</th>
            <th>Full Name</th>
            <th>Company Name</th>
            <th>Current Active Plan</th>
            <th>Unpaid Invoices</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.CustomerId</td>
                <td>@customer.FullName</td>
                <td>@customer.CompanyName</td>
                <td>@customer.CurrentActivePlan</td>
                <td>
                    @if (customer.HasUnpaidInvoices)
                    {
                        <span class="badge bg-danger">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-success">No</span>
                    }
                </td>
                <td>
                    <a asp-action="EditCustomer" asp-route-id="@customer.CustomerId" class="btn btn-sm btn-primary">View / Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>
