@model EmreGeydirenler_Lab2.Models.SubscriptionPlan

@{
    ViewData["Title"] = "Create Plan";
}

<h2>Create Subscription Plan</h2>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="PlanName" class="form-label"></label>
        <input asp-for="PlanName" class="form-control" />
        <span asp-validation-for="PlanName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MonthlyPrice" class="form-label"></label>
        <input asp-for="MonthlyPrice" class="form-control" />
        <span asp-validation-for="MonthlyPrice" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MaxUsers" class="form-label"></label>
        <input asp-for="MaxUsers" class="form-control" />
        <span asp-validation-for="MaxUsers" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="ManagePlans" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
