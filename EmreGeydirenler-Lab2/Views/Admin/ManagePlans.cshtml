@model IEnumerable<EmreGeydirenler_Lab2.Models.SubscriptionPlan>

@{
    ViewData["Title"] = "Manage Plans";
}

<h1>Manage Subscription Plans</h1>

<p>Here you can manage the subscription plans for the platform.</p>
<p>
    <a asp-action="Create" class="btn btn-success">Create New Plan</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Plan Name</th>
            <th>Monthly Price</th>
            <th>Max Users</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var plan in Model)
            {
                <tr>
                    <td>@plan.Id</td>
                    <td>@plan.PlanName</td>
                    <td>$@plan.MonthlyPrice.ToString("0.00")</td>
                    <td>@plan.MaxUsers</td>
                    <td>@(plan.IsActive ? "Active" : "Inactive")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@plan.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>