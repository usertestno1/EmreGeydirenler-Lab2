@model IEnumerable<EmreGeydirenler_Lab2.Models.AdminUserListItemViewModel>

@{
    ViewData["Title"] = "Admin Users";
}

<h2>Admin Users</h2>
<p class="text-muted">Read-only list of administrator accounts.</p>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Admin ID</th>
            <th>Full Name</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var admin in Model)
        {
            <tr>
                <td>@admin.Id</td>
                <td>@admin.FullName</td>
                <td>@admin.Email</td>
            </tr>
        }
    </tbody>
</table>
